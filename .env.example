# Database Configuration
DB_URL=jdbc:mysql://localhost:3306/ik_system?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=ik_user
DB_PASSWORD=ik_password

# JWT Configuration
JWT_SECRET=super-secret-key-that-must-be-at-least-256-bits-long-for-hmac-sha
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# AWS S3 Configuration
AWS_S3_BUCKET=your-bucket-name
AWS_S3_REGION=eu-central-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
